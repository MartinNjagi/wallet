# ==========================================
# APP / SERVER CONFIGURATION
# ==========================================
# Options: local, development, staging, production
APP_ENV=local
SERVER_HOST=http://localhost
SERVER_PORT=8080
LOG_DIR=./logs
DEBUG=1

# ==========================================
# DATABASE (MySQL)
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=wallet_db

# ==========================================
# REDIS CONFIGURATION
# ==========================================
# Note: REDIS_ADDR overrides HOST/PORT if set
REDIS_ADDR=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# SECURITY & AUTHENTICATION
# ==========================================
JWT_SECRET=your_jwt_signing_secret_here
INTERNAL_SERVICE_TOKEN=your_internal_microservice_hmac_secret

# ==========================================
# INTERNAL MICROSERVICE URLs
# ==========================================
IDENTITY_SERVICE_URL=http://localhost:8081
WALLET_SERVICE_URL=http://localhost:8082
SDP_SERVICE_URL=http://localhost:8083
SMS_SERVICE_URL=http://localhost:8084

# ==========================================
# SMS / NOTIFICATION SETTINGS
# ==========================================
SENDER_ID=YOUR_BRAND_NAME

# ==========================================
# STORAGE (AWS S3 or MinIO)
# ==========================================
# The app prioritizes AWS if region is set and MinIO endpoint is empty.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=my-wallet-bucket

# Local MinIO Fallback Setup
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ==========================================
# SAFARICOM M-PESA DARAJA API
# ==========================================
# Endpoints
mpesa_access_token_url=https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials
mpesa_stk_push_endpoint=https://sandbox.safaricom.co.ke/mpesa/stkpush/v1/processrequest

# Credentials
c2b_consumer_key=your_consumer_key
c2b_consumer_secret=your_consumer_secret
c2b_paybill=174379
c2b_passkey=your_passkey
c2b_party_b=174379
transaction_type=CustomerPayBillOnline

# Webhooks / Callbacks
# MPESA_WEBHOOK_HOST should be publicly accessible (e.g. ngrok domain during dev)
MPESA_WEBHOOK_HOST=https://your-public-domain.com
MPESA_WEBHOOK_SECRET=your_webhook_security_string

# M-Pesa B2C / Reversals / Disputes
MPESA_INITIATOR_NAME=testapiuser
MPESA_INITIATOR_PASSWORD=testapi_password